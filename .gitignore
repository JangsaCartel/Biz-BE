##############################
# ? 기본 설정
##############################

# OS별 불필요 파일
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

##############################
# ? Eclipse 관련
##############################

# Eclipse 프로젝트 메타데이터
.project
.classpath
.factorypath
.settings/
*.launch
*.buildship/

# Eclipse Buildship 플러그인 캐시
.buildship/

##############################
# ?? Gradle 관련
##############################

# Gradle 캐시 및 빌드 파일
.gradle/
build/
bin/
out/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# Gradle GUI 관련
gradle-app.setting
.gradletasknamecache

##############################
# ? Java 관련
##############################

# 컴파일된 클래스
*.class

# 로그 파일
*.log
logs/

# Java 힙 덤프 파일
*.hprof

# 임시 파일
*.tmp
*.bak

##############################
# ? 패키징 파일
##############################

#  WAR, EAR 등 배포 아카이브
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

##############################
# ? IDE 관련 (VSCode 등)
##############################

# VSCode 관련
.vscode/

# IntelliJ 관련 (혹은 사용할 경우)
.idea/
*.iml
*.ipr
*.iws

##############################
# ? 민감한 정보 (보안)
##############################

# Spring Boot 관련 (환경에 따라 달라지는 정보)
application.properties
application.yml
application-local.properties
application-local.yml

src/main/resources/application.properties


##############################
# ? 기타
##############################

# 로그, 임시, 캐시 디렉토리
tmp/
cache/

##############################
# WEB-INF 관련 설정 (주의)
##############################

# WEB-INF 관련 파일들은 보통(*) 기본적으로 무시합니다.
WEB-INF/*

# 예외 처리: 반드시 Git에 포함해야 하는 리소스 코드 및 설정 파일
!WEB-INF/web.xml
!WEB-INF/views/   # JSP 파일 등 뷰 리소스 코드를 쓰는 경우에 포함

# 무시 목록: 라이브러리나 컴파일된 클래스는 무시
WEB-INF/lib/      # 라이브러리 파일
WEB-INF/classes/  # 컴파일된 .class 파일

# 모든 properties 파일 무시 (보안/설정 파일)
*.properties
